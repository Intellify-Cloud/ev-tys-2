  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Team | ConsultancyPro</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n      tailwind.config = {\n        darkMode: \"class\",\n        theme: {\n          extend: {\n            colors: {\n              \"surface-dim\": \"#d1dce0\",\n              \"on-error-container\": \"#752121\",\n              \"surface-bright\": \"#f8f9fa\",\n              \"on-background\": \"#2b3437\",\n              \"error-dim\": \"#4e0309\",\n              \"tertiary-fixed\": \"#d6dbfb\",\n              \"tertiary\": \"#585e78\",\n              \"primary-container\": \"#d2e4fb\",\n              \"surface-container-lowest\": \"#ffffff\",\n              \"secondary-dim\": \"#415660\",\n              \"secondary-fixed\": \"#cfe6f2\",\n              \"on-secondary-fixed\": \"#2d424c\",\n              \"secondary-fixed-dim\": \"#c1d8e4\",\n              \"on-tertiary-container\": \"#474d67\",\n              \"error\": \"#9f403d\",\n              \"on-surface-variant\": \"#586064\",\n              \"secondary\": \"#4d626c\",\n              \"on-secondary-fixed-variant\": \"#495f69\",\n              \"error-container\": \"#fe8983\",\n              \"surface-container\": \"#eaeff1\",\n              \"on-tertiary-fixed-variant\": \"#515771\",\n              \"outline\": \"#737c7f\",\n              \"on-tertiary-fixed\": \"#353b53\",\n              \"inverse-surface\": \"#0c0f10\",\n              \"surface-container-low\": \"#f1f4f6\",\n              \"primary-fixed-dim\": \"#c4d6ed\",\n              \"secondary-container\": \"#cfe6f2\",\n              \"on-error\": \"#fff7f6\",\n              \"surface-container-high\": \"#e3e9ec\",\n              \"surface\": \"#f8f9fa\",\n              \"on-surface\": \"#2b3437\",\n              \"surface-variant\": \"#dbe4e7\",\n              \"on-primary-container\": \"#425366\",\n              \"surface-tint\": \"#4f6073\",\n              \"on-primary\": \"#f5f8ff\",\n              \"on-tertiary\": \"#faf8ff\",\n              \"on-secondary\": \"#f2faff\",\n              \"background\": \"#f8f9fa\",\n              \"tertiary-fixed-dim\": \"#c8cdec\",\n              \"tertiary-container\": \"#d6dbfb\",\n              \"outline-variant\": \"#abb3b7\",\n              \"primary-fixed\": \"#d2e4fb\",\n              \"on-primary-fixed\": \"#304153\",\n              \"tertiary-dim\": \"#4c526c\",\n              \"primary-dim\": \"#435467\",\n              \"on-secondary-container\": \"#40555f\",\n              \"primary\": \"#4f6073\",\n              \"inverse-on-surface\": \"#9b9d9e\",\n              \"inverse-primary\": \"#d5e7fe\",\n              \"surface-container-highest\": \"#dbe4e7\",\n              \"on-primary-fixed-variant\": \"#4c5d70\"\n            },\n            fontFamily: {\n              \"headline\": [\"Manrope\"],\n              \"body\": [\"Inter\"],\n              \"label\": [\"Inter\"]\n            },\n            borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n          },\n        },\n      }\n    </script>\n<style>\n        .material-symbols-outlined {\n            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;\n            vertical-align: middle;\n        }\n    </style>\n</head>\n<body class=\"bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container\">\n<!-- TopNavBar -->\n<nav class=\"fixed top-0 w-full z-50 bg-slate-50/80 dark:bg-slate-900/80 backdrop-blur-md\">\n<div class=\"flex justify-between items-center px-8 py-4 max-w-7xl mx-auto\">\n<span class=\"text-xl font-bold text-slate-800 dark:text-slate-100 tracking-tighter font-headline\" style=\"\">ConsultancyPro</span>\n<div class=\"hidden md:flex items-center gap-8\">\n<a class=\"text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-slate-200 transition-colors font-manrope text-sm font-medium tracking-tight\" href=\"#\" style=\"\">Expertise</a>\n<a class=\"text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-slate-200 transition-colors font-manrope text-sm font-medium tracking-tight\" href=\"#\" style=\"\">Process</a>\n<a class=\"text-slate-900 dark:text-white font-bold border-b-2 border-slate-600 dark:border-slate-400 pb-1 font-manrope text-sm tracking-tight\" href=\"#\" style=\"\">Team</a>\n<a class=\"text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-slate-200 transition-colors font-manrope text-sm font-medium tracking-tight\" href=\"#\" style=\"\">Contact</a>\n</div>\n<button class=\"bg-primary text-on-primary px-6 py-2 rounded-lg font-headline text-sm font-semibold transition-all duration-300 ease-in-out hover:bg-primary-dim shadow-sm\" style=\"\">\n                Get Started\n            </button>\n</div>\n</nav>\n<main class=\"pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto\">\n<!-- Hero Section -->\n<header class=\"text-center mb-24 max-w-3xl mx-auto\">\n<h1 class=\"font-headline text-5xl md:text-6xl font-extrabold text-on-surface tracking-tighter mb-6\" style=\"\">Team</h1>\n<p class=\"text-on-surface-variant text-lg md:text-xl leading-relaxed font-body\" style=\"\">\n                Our collective expertise is built on decades of multi-disciplinary experience. We combine analytical precision with creative vision to redefine the architectural consulting landscape.\n            </p>\n</header>\n<!-- Main Team Module -->\n<section class=\"grid grid-cols-1 lg:grid-cols-12 gap-6 items-stretch\">\n<!-- Left Column: Office Hours (Asymmetric Layout Component) -->\n<div class=\"lg:col-span-5 bg-surface-container-low rounded-xl p-10 flex flex-col justify-center border border-outline-variant/10\">\n<div class=\"flex items-center gap-4 mb-8\">\n<span class=\"material-symbols-outlined text-primary text-3xl\" data-icon=\"schedule\" style=\"\">schedule</span>\n<h2 class=\"font-headline text-2xl font-bold tracking-tight text-on-surface\" style=\"\">Office Hours</h2>\n</div>\n<div class=\"space-y-8\">\n<div class=\"group\">\n<label class=\"font-label text-xs uppercase tracking-[0.15em] text-on-surface-variant mb-2 block\" style=\"\">Standard Operations</label>\n<p class=\"font-headline text-xl text-on-surface font-medium\" style=\"\"><b>Open</b> : Mon to Fri 8:00 AM - 5:00 PM</p>\n</div>\n<div class=\"group\">\n<label class=\"font-label text-xs uppercase tracking-[0.15em] text-on-surface-variant mb-2 block\" style=\"\">Exceptions</label>\n<p class=\"font-headline text-xl text-on-surface font-medium opacity-80\" style=\"\"><b>Closed </b>: Sundays and Public Holidays</p>\n</div>\n<div class=\"mt-8 pt-8 border-t border-outline-variant/15\">\n<div class=\"flex items-center gap-3 text-on-surface-variant text-sm italic\">\n<span class=\"material-symbols-outlined text-lg\" data-icon=\"info\" style=\"\">info</span>\n<span class=\"\" style=\"\">Response times may vary during peak advisory periods.</span>\n</div>\n</div>\n</div>\n</div>\n<!-- Right Column: Featured Team Member (Editorial Card) -->\n<div class=\"lg:col-span-7 bg-surface-container-lowest rounded-xl overflow-hidden flex flex-col md:flex-row shadow-[0_12px_32px_rgba(43,52,55,0.06)] border border-outline-variant/5\">\n<div class=\"md:w-1/2 relative min-h-[300px]\">\n<img alt=\"Professional Team Member\" class=\"absolute inset-0 w-full h-full object-cover\" data-alt=\"close-up portrait of a professional male consultant in a tailored grey suit against a blurred modern architectural interior office background\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAboJmiollc5MIHTbRQ7v_qZeKhk6XFowKOxxWrAgV5HeHqG058m0KotR4uvGZvxMu6bAEaOBU4B8RNb-5VM55Oyqu-pYwtesTheY-T2UeeruoAwkjNyeELindwFkYjSRlWUaikjyWqy-jzyH69OS0X_-90E1I2cfHw3Sqtsb_4dGX50d57GaZUKw8oq-iQQoHPhhxVXfLEfUpiAEsSankpNCvFLyOfN1X1OL1r1Ey_Ybqp8W4VqgiVPtZzBSiGZF9_lR5u0CTDQI5-\" style=\"\"/>\n</div>\n<div class=\"md:w-1/2 p-10 flex flex-col justify-center\">\n<div class=\"mb-6\">\n<h3 class=\"font-headline text-3xl font-extrabold text-on-surface tracking-tighter leading-none mb-1\" style=\"\">Name Surname</h3>\n<p class=\"font-label text-sm uppercase tracking-widest text-primary font-bold\" style=\"\">Consultant</p>\n</div>\n<p class=\"text-on-surface-variant mb-10 leading-relaxed font-body text-sm italic\" style=\"\">\n                        Specializing in strategic spatial planning and corporate ecosystem optimization for global firm integration.\n                    </p>\n<div class=\"flex items-center gap-4\">\n<a aria-label=\"Call\" class=\"w-12 h-12 flex items-center justify-center bg-primary-container text-on-primary-container rounded-lg transition-all duration-300 hover:bg-primary-fixed-dim\" href=\"tel:#\" style=\"\">\n<span class=\"material-symbols-outlined\" data-icon=\"call\" style=\"\">call</span>\n</a>\n<a aria-label=\"Email\" class=\"w-12 h-12 flex items-center justify-center bg-primary-container text-on-primary-container rounded-lg transition-all duration-300 hover:bg-primary-fixed-dim\" href=\"mailto:#\" style=\"\">\n<span class=\"material-symbols-outlined\" data-icon=\"mail\" style=\"\">mail</span>\n</a>\n<a aria-label=\"WhatsApp\" class=\"w-12 h-12 flex items-center justify-center bg-primary-container text-on-primary-container rounded-lg transition-all duration-300 hover:bg-primary-fixed-dim\" href=\"#\" style=\"\">\n<span class=\"material-symbols-outlined\" data-icon=\"chat\" style=\"\">chat</span>\n</a>\n</div>\n</div>\n</div>\n</section>\n<!-- Secondary Team Grid (Visual Depth) -->\n<section class=\"mt-24\">\n<label class=\"font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant mb-12 block text-center\" style=\"\">Global Partners &amp; Leads</label>\n<div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8\">\n<!-- Mini Card 1 -->\n<div class=\"group\">\n<div class=\"aspect-square rounded-xl bg-surface-container-high overflow-hidden mb-4 relative transition-all duration-500 group-hover:shadow-lg\">\n<img alt=\"Team Lead\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" data-alt=\"professional woman in navy blazer smiling in a bright airy office setting with natural window lighting\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAwGc8zhMVwi7yIeuZGGlzHsK0msqnMHNuWUptZg9WP2z-8OBcndkO-WRURvx7ByNq29cn2iGKq-tcjYiverS9VIk96LCJI41GjUG428c3UmAkH-SoSgFv4dMltyt5-ds31jnfyZNqaQ0_r6rDg2d0gHagzn1qpwi8-JVScaEaozvNDfIROBeYo_a9h_nvr5yxJRvkPnDeMnCQb5Z2oRLOIvPRRuneR2eKPI62hZ4su6RWlheUvMTKm5Zf-XLfSAsgL6FGZq47LAmAc\" style=\"\"/>\n</div>\n<h4 class=\"font-headline font-bold text-on-surface\" style=\"\">Elena Rodriguez</h4>\n<p class=\"text-xs uppercase tracking-widest text-on-surface-variant\" style=\"\">Director of Strategy</p>\n</div>\n<!-- Mini Card 2 -->\n<div class=\"group\">\n<div class=\"aspect-square rounded-xl bg-surface-container-high overflow-hidden mb-4 relative transition-all duration-500 group-hover:shadow-lg\">\n<img alt=\"Lead Architect\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\" data-alt=\"confident professional man with glasses standing in a high-tech minimalist meeting room\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuC05yw4yFFT-j3qHI0vTZJV1WQDCuYnfH468adNfO52CrslmoalTSBiH7je3A3l1KReiuprCq268QGm4KiqaarJhQlNeA1wNnJmS312_f5lh-21dNLC0pYxGwsQ